# =============================================================================
# Big Data Lab — Environment Variables
# Copy this file to .env before running docker-compose up
# Do NOT commit .env to version control
# =============================================================================

# Hadoop image tag
HADOOP_IMAGE_TAG=2.0.0-hadoop3.2.1-java8

# PostgreSQL metastore credentials
POSTGRES_DB=metastore
POSTGRES_USER=hive
POSTGRES_PASSWORD=hive_lab_2024

# Hue pinned image
HUE_IMAGE=gethue/hue:4.11.0

# Hive heap size in MB
HADOOP_HEAPSIZE=2048

# HDFS cluster name
CLUSTER_NAME=bigdata-lab
